# Copy to .env.local for local development. Set the real values in the Vercel
# project settings for preview and production (see CLAUDE.md, Section 7.6).

# Vercel Postgres — saved scenarios, territory defaults, user roles
POSTGRES_URL=

# Vercel KV — cache of simulation results keyed by scenario hash
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Trained GNN artifact location (Vercel Blob or object storage)
GRIDGUARD_MODEL_URL=
